---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/base/Container.astro";
import Prose from "../components/base/Prose.astro";

interface Props {
  title: string;
  deck: string;
  topic: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
}

const {
  title,
  deck,
  topic,
  author,
  publishDate,
  updatedDate,
} = Astro.props;

const pageTitle = `${title} | Lookout West`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  }).format(date);

const publishedLabel = formatDate(publishDate);
const updatedLabel = updatedDate ? formatDate(updatedDate) : null;
---

<BaseLayout title={pageTitle} description={deck}>
  <article class="article-layout">
    <Container>
      <header class="article-layout__header">
        <p class="article-layout__eyebrow">{topic}</p>
        <h1 class="article-layout__title">{title}</h1>
        <p class="article-layout__deck">{deck}</p>

        <div class="article-layout__meta" aria-label="Article metadata">
          <span class="article-layout__meta-item article-layout__meta-item--author">
            By {author}
          </span>
          <span class="article-layout__meta-separator" aria-hidden="true">•</span>
          <span class="article-layout__meta-item">
            Published <time datetime={publishDate.toISOString()}>{publishedLabel}</time>
          </span>

          {updatedLabel && (
            <>
              <span class="article-layout__meta-separator" aria-hidden="true">•</span>
              <span class="article-layout__meta-item">
                Updated <time datetime={updatedDate?.toISOString()}>{updatedLabel}</time>
              </span>
            </>
          )}
        </div>
      </header>
    </Container>

    {Astro.slots.has("hero") && (
      <Container>
        <div class="article-layout__hero">
          <slot name="hero" />
        </div>
      </Container>
    )}

    <Container>
      <section class="article-layout__body">
        <Prose>
          <slot />
        </Prose>
      </section>
    </Container>

    {Astro.slots.has("sources") && (
      <Container>
        <section class="article-layout__sources">
          <h2 class="article-layout__sources-title">Sources</h2>
          <div class="article-layout__sources-body">
            <slot name="sources" />
          </div>
        </section>
      </Container>
    )}
  </article>
</BaseLayout>

<style>
  .article-layout__header {
    width: min(100%, 46rem);
    padding-top: var(--space-7);
    padding-bottom: var(--space-6);
  }

  .article-layout__eyebrow {
    margin: 0 0 var(--space-2);
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-layout__title {
    margin: 0;
    max-width: 10ch;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .article-layout__deck {
    width: min(100%, 38rem);
    margin: var(--space-4) 0 0;
    color: var(--color-muted);
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.62;
  }

  .article-layout__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.65rem;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: var(--border-subtle);
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.4;
  }

  .article-layout__meta-item--author {
    color: var(--color-text);
  }

  .article-layout__meta-separator {
    color: var(--color-muted);
    opacity: 0.7;
  }

  .article-layout__hero {
    margin-bottom: var(--space-7);
  }

  .article-layout__body {
    padding-bottom: var(--space-9);
  }

  .article-layout__sources {
    width: min(100%, 42rem);
    padding-top: var(--space-7);
    padding-bottom: var(--space-9);
    border-top: var(--border-subtle);
  }

  .article-layout__sources-title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .article-layout__sources-body {
    color: var(--color-muted);
  }

  .article-layout__sources-body :global(ol),
  .article-layout__sources-body :global(ul) {
    margin: 0;
    padding-left: 1.25rem;
  }

  .article-layout__sources-body :global(li) {
    line-height: 1.55;
  }

  .article-layout__sources-body :global(li + li) {
    margin-top: 0.85rem;
  }

  .article-layout__sources-body :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 0.06em;
  }

  .article-layout__sources-body :global(.article-source__meta) {
    display: block;
    margin-top: 0.2rem;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  @media (max-width: 56rem) {
    .article-layout__header {
      width: 100%;
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }

    .article-layout__title {
      max-width: 9ch;
      font-size: clamp(2.15rem, 10.5vw, 3.5rem);
      line-height: 0.97;
    }

    .article-layout__deck {
      width: 100%;
      margin-top: var(--space-3);
      font-size: 1.0625rem;
      line-height: 1.66;
    }

    .article-layout__meta {
      gap: 0.35rem 0.55rem;
      margin-top: var(--space-3);
      padding-top: var(--space-3);
    }

    .article-layout__hero {
      margin-bottom: var(--space-6);
    }

    .article-layout__body {
      padding-bottom: var(--space-8);
    }

    .article-layout__sources {
      width: 100%;
      padding-top: var(--space-6);
      padding-bottom: var(--space-8);
    }
  }
</style>
