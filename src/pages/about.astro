---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="About"
  description="Lookout West is an independent publication on the economics of the American West."
  eyebrow="Why we exist"
  intro="We provide leading, independent economic analysis of the American West."
  prose={false}
  contentWidth="wide"
>
  <div class="about-page">
    <section class="about-section">
      <div class="about-section__header">
        <p class="about-section__label"></p>
        <h2 class="about-section__title">
          The story of the West, has always been a story about economics.
        </h2>
        <p class="about-section__description">
          The region has always demanded we face relentless economic forces:
          Who can afford to live where, how water gets allocated, where power demand is going,
          what growth does to local institutions, and how physical constraint shapes opportunity.
        </p>
        <p class="about-section__description">
          Those complex questions require serious engagement. Lookout West provides rigorous, region-specific analytics grounded in local data and economic theory,
          built to help Western communities make clearer decisions under constraint.
        </p>

    <section class="about-section">
      <div class="about-section__header">
        <p class="about-section__label"></p>
        <h2 class="about-section__title">
          People need analysis they can use from a source they can trust.
        </h2>
        <p class="about-section__description">
          We built Lookout West to focus squarely on the American West, and we are proud to be based here.
          We know this region is one of the places where some of the biggest economic questions are
          being tested in real time. We hope readers feel that connection:
          to the place, to the stakes, and to reporting that understands both.
        </p>
        <p class="about-section__description">
          Good analysis should not require a policy background or hours of spare time.
          Lookout West is built for readers who want serious work in plain language: useful, rigorous, and clear enough to carry into the rest of your day.
        </p>
      </div>
    </section>

    <section class="about-cta">
      <p class="about-cta__label">Next steps</p>
      <h2 class="about-cta__title">
        Start with the research. Subscribe if you want the next piece. Reach out when there is a concrete question.
      </h2>

      <div class="about-cta__actions">
        <a class="button button--primary" href="/research">Read the research</a>
        <button class="button" type="button" data-subscribe-open>
          Subscribe
        </button>
        <a class="button" href="/contact">Start an inquiry</a>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .about-page {
    display: grid;
    gap: var(--space-7);
  }

  .about-section {
    display: grid;
    gap: var(--space-5);
  }

  .about-section + .about-section {
    padding-top: var(--space-5);
    border-top: var(--border-subtle);
  }

  .about-hero,
  .about-card,
  .coverage-card,
  .about-cta {
    padding: var(--space-5);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.52);
  }

  .about-hero {
    width: min(100%, 68rem);
  }

  .about-cta {
    padding: var(--space-6);
  }

  .about-hero__content {
    max-width: 42rem;
  }

  .about-section__header {
    max-width: 44rem;
  }

  .about-section__body {
    max-width: 42rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.75;
  }

  .about-section__body p {
    margin: 0;
  }

  .about-section__body p + p {
    margin-top: var(--space-4);
  }

  .about-hero__label,
  .about-section__label,
  .about-cta__label {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-hero__title {
    margin: var(--space-2) 0 0;
    max-width: 18ch;
    font-family: var(--font-display);
    font-size: clamp(1.48rem, 1.9vw, 1.86rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .about-hero__deck,
  .about-hero__note {
    max-width: 40rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .about-hero__deck {
    margin: var(--space-4) 0 0;
  }

  .about-hero__note {
    margin: var(--space-3) 0 0;
  }

  .about-section__description {
    margin-top: var(--space-4);
    max-width: 44rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .about-section__description + .about-section__description {
    margin-top: var(--space-3);
  }

  .about-section__title,
  .about-cta__title {
    margin: var(--space-2) 0 0;
    max-width: 27ch;
    font-family: var(--font-display);
    font-size: clamp(1.26rem, 1.55vw, 1.52rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .about-grid,
  .coverage-grid {
    display: grid;
    gap: var(--space-4);
  }

  .about-card,
  .coverage-card {
    display: grid;
    align-content: start;
    gap: var(--space-3);
  }

  .about-card h3,
  .coverage-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(0.98rem, 1.02vw, 1.1rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .about-card p,
  .coverage-card p {
    margin: 0;
    max-width: 31ch;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .about-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  @media (min-width: 68rem) {
    .about-cta {
      width: min(100%, 44rem);
    }

    .about-grid,
    .coverage-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .about-section--split {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      align-items: start;
      column-gap: var(--space-7);
    }

    .about-section--split .about-section__header {
      max-width: 28rem;
    }
  }

  @media (max-width: 56rem) {
    .about-page {
      gap: var(--space-6);
    }

    .about-section + .about-section {
      padding-top: var(--space-4);
    }

    .about-hero,
    .about-card,
    .coverage-card,
    .about-cta {
      border-radius: var(--radius-md);
    }

    .about-hero__deck,
    .about-hero__note,
    .about-section__description,
    .about-section__body {
      font-size: 1.0625rem;
    }
  }
</style>
