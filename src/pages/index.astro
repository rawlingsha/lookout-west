---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/base/Container.astro";
import SignupBlock from "../components/home/SignupBlock.astro";

const pageTitle = "Lookout West | Research, data, and decisions in the American West";
const pageDescription =
  "Independent research, data, and economic analysis on the American West.";

const allArticles = await getCollection("articles");

const publishedArticles = allArticles
  .filter((article) => !article.data.draft)
  .sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  );

const featuredArticle =
  publishedArticles.find((article) => article.data.featured) ??
  publishedArticles[0] ??
  null;

const latestArticles = publishedArticles
  .filter((article) => article.id !== featuredArticle?.id)
  .slice(0, 4);

const featuredCardImage =
  featuredArticle?.data.showCardImage && featuredArticle.data.cardImage
    ? featuredArticle.data.cardImage
    : null;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  }).format(date);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Container>
    <section class="hero">
      <div class="hero__content">
        <p class="hero__eyebrow">Research, data, and decisions.</p>
        <h1 class="hero__title">The American West analyzed.</h1>
        <p class="hero__deck">
          Leading economics. Always independent.
        </p>

        <div class="hero__actions">
          <a class="button button--primary" href="/research">Browse research</a>
          <a class="button" href="/services">View services</a>
        </div>
      </div>

      {featuredArticle && (
        <article class={`hero-feature ${featuredCardImage ? "hero-feature--visual" : ""}`}>
          {featuredCardImage && (
            <a
              class="hero-feature__visual"
              href={`/research/${featuredArticle.id}/`}
              aria-label={`Read ${featuredArticle.data.title}`}
            >
              <img
                src={featuredCardImage}
                alt={featuredArticle.data.cardImageAlt ?? ""}
                loading="eager"
              />
            </a>
          )}

          <p class="hero-feature__topic">{featuredArticle.data.topic}</p>
          <h2 class="hero-feature__title">
            <a href={`/research/${featuredArticle.id}/`}>
              {featuredArticle.data.title}
            </a>
          </h2>
          <p class="hero-feature__deck">{featuredArticle.data.deck}</p>
          <div class="hero-feature__meta">
            <span>{featuredArticle.data.author}</span>
            <span aria-hidden="true">•</span>
            <time datetime={featuredArticle.data.publishDate.toISOString()}>
              {formatDate(featuredArticle.data.publishDate)}
            </time>
          </div>
        </article>
      )}
    </section>

    {latestArticles.length > 0 && (
      <section class="front-section">
        <div class="front-section__header">
          <p class="front-section__label">Latest</p>
          </p>
        </div>

        <div class="story-grid">
          {latestArticles.map((article) => {
            const href = `/research/${article.id}/`;
            const cardImage =
              article.data.showCardImage && article.data.cardImage
                ? article.data.cardImage
                : null;

            return (
              <article class={`story-card ${cardImage ? "story-card--visual" : ""}`}>
                {cardImage && (
                  <a
                    class="story-card__visual"
                    href={href}
                    aria-label={`Read ${article.data.title}`}
                  >
                    <img
                      src={cardImage}
                      alt={article.data.cardImageAlt ?? ""}
                      loading="lazy"
                    />
                  </a>
                )}

                <div class="story-card__body">
                  <p class="story-card__topic">{article.data.topic}</p>
                  <h3 class="story-card__title">
                    <a href={href}>{article.data.title}</a>
                  </h3>
                  <p class="story-card__deck">{article.data.deck}</p>
                  <p class="story-card__meta">
                    <time datetime={article.data.publishDate.toISOString()}>
                      {formatDate(article.data.publishDate)}
                    </time>
                  </p>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <section class="front-section">
      <div class="front-section__header">
        <p class="front-section__label">Advisory work</p>
        <h2 class="front-section__title">
          Consultancy should feel like an extension of the publication.
        </h2>
        <p class="front-section__description">
          The service surface should read as specific, serious, and decision-useful for
          institutions operating in the West.
        </p>
      </div>

      <div class="service-grid">
        <article class="service-card">
          <p class="service-card__label">Executive briefings</p>
          <h3>Concise regional intelligence for leaders who need signal, not noise.</h3>
          <p>
            Structured briefings on land, water, energy, housing, labor, and growth.
          </p>
        </article>

        <article class="service-card">
          <p class="service-card__label">Custom research</p>
          <h3>Decision-oriented analysis shaped to a client’s operating questions.</h3>
          <p>
            Built for utilities, public agencies, investors, and regional institutions.
          </p>
        </article>

        <article class="service-card">
          <p class="service-card__label">Speaking</p>
          <h3>Clear, data-literate framing for boards, conferences, and stakeholder groups.</h3>
          <p>
            The goal is credibility and clarity, not generic keynote language.
          </p>
        </article>
      </div>

      <div class="front-section__actions">
        <a class="button button--primary" href="/services">Explore services</a>
        <a class="button" href="/contact">Make contact</a>
      </div>
    </section>
    <SignupBlock />
  </Container>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: var(--space-6);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .hero__eyebrow,
  .front-section__label,
  .hero-feature__label,
  .hero-feature__topic,
  .story-card__topic,
  .service-card__label {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--step--1);
    font-weight: 600;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-3);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 10ch;
    text-wrap: balance;
  }

  .hero__deck {
    max-width: 42rem;
    font-size: var(--step-1);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .hero__actions,
  .front-section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .hero-feature,
  .story-card,
  .service-card {
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.6);
  }

  .hero-feature {
    padding: var(--space-6);
    align-self: end;
    overflow: hidden;
  }

  .hero-feature__visual {
    display: block;
    aspect-ratio: 16 / 10;
    margin: calc(var(--space-6) * -1) calc(var(--space-6) * -1) var(--space-5);
    border-bottom: var(--border-subtle);
    background:
      linear-gradient(135deg, rgba(74, 93, 68, 0.16), rgba(218, 168, 94, 0.16));
    overflow: hidden;
  }

  .hero-feature__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .hero-feature__visual:hover img,
  .hero-feature__visual:focus-visible img {
    transform: scale(1.02);
  }

  .hero-feature__topic {
    margin: 0 0 var(--space-2);
  }

  .hero-feature__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .hero-feature__deck {
    margin: var(--space-4) 0 0;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .hero-feature__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  .hero-feature__title a:hover,
  .hero-feature__title a:focus-visible,
  .story-card__title a:hover,
  .story-card__title a:focus-visible {
    color: var(--color-accent);
  }

  .front-section {
    padding-top: var(--space-7);
    padding-bottom: var(--space-7);
    border-top: var(--border-subtle);
  }

  .front-section__header {
    max-width: 46rem;
    margin-bottom: var(--space-5);
  }

  .front-section__title {
    margin: var(--space-2) 0 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .front-section__description {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--step-1);
    line-height: 1.7;
  }

  .story-grid,
  .service-grid {
    display: grid;
    gap: var(--space-4);
  }

  .service-card {
    padding: var(--space-5);
  }

  .story-card {
    overflow: hidden;
  }

  .story-card:not(.story-card--visual) {
    padding: var(--space-5);
  }

  .story-card:not(.story-card--visual) .story-card__body {
    padding: 0;
  }

  .story-card__body {
    padding: var(--space-5);
  }

  .story-card__visual {
    display: block;
    aspect-ratio: 16 / 9;
    border-bottom: var(--border-subtle);
    background:
      linear-gradient(135deg, rgba(74, 93, 68, 0.16), rgba(218, 168, 94, 0.16));
    overflow: hidden;
  }

  .story-card__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .story-card__visual:hover img,
  .story-card__visual:focus-visible img {
    transform: scale(1.025);
  }

  .story-card__topic,
  .service-card__label {
    margin: 0 0 var(--space-3);
  }

  .story-card__title,
  .service-card h3 {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .story-card__title {
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
  }

  .service-card h3 {
    font-size: clamp(1.35rem, 2vw, 1.85rem);
  }

  .story-card__deck,
  .service-card p:last-child {
    margin: var(--space-4) 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .story-card__status,
  .story-card__meta {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  @media (min-width: 68rem) {
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(23rem, 0.85fr);
      align-items: start;
      column-gap: var(--space-8);
    }

    .hero-feature__visual {
      aspect-ratio: 16 / 7.5;
    }

    .story-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 68rem) {
    .hero {
      padding-bottom: var(--space-5);
    }

    .hero-feature__visual {
      aspect-ratio: 16 / 7;
    }
  }

  @media (max-width: 56rem) {
    .hero {
      padding-top: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .hero__title {
      max-width: 9ch;
      font-size: clamp(2.2rem, 11vw, 3.8rem);
      line-height: 0.97;
    }

    .hero__deck,
    .front-section__description {
      font-size: 1.0625rem;
    }

    .front-section {
      padding-top: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .hero-feature,
    .story-card,
    .service-card {
      border-radius: var(--radius-md);
    }
  }
</style>
