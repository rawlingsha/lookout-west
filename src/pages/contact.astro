---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Contact"
  description="Contact Lookout West for research, speaking, and advisory inquiries."
  eyebrow="Contact"
  intro="For research, speaking, or advisory inquiries, reach out directly."
  prose={false}
  contentWidth="wide"
>
  <div class="contact-page">
    <section class="contact-hero">
      <div class="contact-hero__content">
        <p class="contact-hero__label">Advisory inquiries</p>
        <h2 class="contact-hero__title">
          For advisory, speaking, or editorial collaboration, the cleanest path is still a direct email.
        </h2>
        <p class="contact-hero__deck">
          If you are reaching out about a briefing, custom research project, speaking
          opportunity, or collaboration, send a note with enough context to frame the ask well.
          Readers who simply want new essays and notes should use the subscription flow in the
          header.
        </p>

        <div class="contact-hero__actions">
          <a class="button button--primary" href="mailto:hello@lookoutwest.us">hello@lookoutwest.us</a>
          <a class="button" href="/services">Review services</a>
        </div>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-section__header">
        <p class="contact-section__label">Best inquiries</p>
        <h2 class="contact-section__title">
          The strongest outreach is concrete about the institution, question, and outcome.
        </h2>
      </div>

      <div class="contact-grid">
        <article class="contact-card">
          <h3>Briefings</h3>
          <p>
            Include the audience, the decision context, and the regional themes that matter most.
          </p>
        </article>

        <article class="contact-card">
          <h3>Custom research</h3>
          <p>
            Include the core question, timeline, and whether the need is strategic, analytical, or editorial.
          </p>
        </article>

        <article class="contact-card">
          <h3>Speaking</h3>
          <p>
            Include the event, audience type, timing, and the subject area you want covered.
          </p>
        </article>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-section__header">
        <p class="contact-section__label">Helpful context</p>
        <h2 class="contact-section__title">
          A short note is fine, but these details make the conversation sharper.
        </h2>
      </div>

      <div class="details-card">
        <ul class="details-list">
          <li>Who you are and what organization you represent</li>
          <li>What question or decision is driving the inquiry</li>
          <li>What kind of output you need: briefing, research, speaking, or another format</li>
          <li>Any timing, audience, or scope constraints that matter up front</li>
        </ul>
      </div>
    </section>

    <section class="contact-section">
      <div class="contact-section__header">
        <p class="contact-section__label">Current scope</p>
        <h2 class="contact-section__title">
          Lookout West is focused on serious work tied to the economics of the American West.
        </h2>
        <p class="contact-section__description">
          That includes land, water, energy, housing, labor, growth, and the regional systems
          that shape long-run economic outcomes.
        </p>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .contact-page {
    display: grid;
    gap: var(--space-7);
  }

  .contact-section {
    display: grid;
    gap: var(--space-5);
  }

  .contact-section + .contact-section {
    padding-top: var(--space-5);
    border-top: var(--border-subtle);
  }

  .contact-hero,
  .contact-card,
  .details-card {
    padding: var(--space-5);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.52);
  }

  .contact-hero {
    width: min(100%, 68rem);
  }

  .contact-hero__content {
    max-width: 38rem;
  }

  .contact-section__header {
    max-width: 42rem;
  }

  .details-card {
    width: min(100%, 56rem);
  }

  .contact-hero__label,
  .contact-section__label {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-hero__title {
    margin: var(--space-2) 0 0;
    max-width: 21ch;
    font-family: var(--font-display);
    font-size: clamp(1.42rem, 1.75vw, 1.7rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .contact-section__title {
    margin: var(--space-2) 0 0;
    max-width: 24ch;
    font-family: var(--font-display);
    font-size: clamp(1.32rem, 1.7vw, 1.58rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .contact-hero__deck {
    margin-top: var(--space-4);
    max-width: 38rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .contact-section__description {
    margin-top: var(--space-4);
    max-width: 42rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .contact-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .contact-grid {
    display: grid;
    gap: var(--space-4);
  }

  .contact-card {
    display: grid;
    align-content: start;
    gap: var(--space-3);
  }

  .contact-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.1vw, 1.16rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .contact-card p {
    margin: 0;
    max-width: 30ch;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .details-list {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text);
  }

  .details-list li {
    line-height: 1.7;
  }

  .details-list li + li {
    margin-top: 0.75rem;
  }

  @media (min-width: 68rem) {
    .contact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 56rem) {
    .contact-page {
      gap: var(--space-6);
    }

    .contact-section + .contact-section {
      padding-top: var(--space-4);
    }

    .contact-hero,
    .contact-card,
    .details-card {
      border-radius: var(--radius-md);
    }

    .contact-hero__deck,
    .contact-section__description {
      font-size: 1.0625rem;
    }
  }
</style>
