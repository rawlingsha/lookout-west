---
import PageLayout from "../layouts/PageLayout.astro";

const inquiryMailto =
  "mailto:lookoutwest.us@gmail.com?subject=Lookout%20West%20inquiry&body=Name%3A%0AOrganization%3A%0AQuestion%20or%20decision%3A%0ATiming%3A%0ARequested%20output%3A%0A";
---

<PageLayout
  title="Contact"
  description="Contact Lookout West for research, speaking, and advisory inquiries."
  eyebrow="Contact"
  intro="For advisory, speaking, or editorial collaboration, start with a short note. Readers who simply want new essays and notes should use the subscription
          button in the header."
  prose={false}
  contentWidth="wide"
>
  <div class="contact-page">
    <section class="contact-hero">
      <div class="contact-hero__content">
        <p class="contact-hero__label">Advisory inquiries</p>
        <h2 class="contact-hero__title">
          Start with a short note. It does not need to be polished.
        </h2>
        <p class="contact-hero__deck">
          If you are reaching out about a briefing, custom research project, speaking
          opportunity, or editorial collaboration, a few concrete details are enough to
          begin. 
        </p>

        <div class="contact-hero__actions">
          <a class="button button--primary" href={inquiryMailto}>Start an email</a>
          <a class="button" href="/services">Review services</a>
        </div>
      </div>
    </section>

</PageLayout>

<style>
  .contact-page {
    display: grid;
    gap: var(--space-7);
  }

  .contact-section {
    display: grid;
    gap: var(--space-5);
  }

  .contact-section + .contact-section {
    padding-top: var(--space-5);
    border-top: var(--border-subtle);
  }

  .contact-hero,
  .contact-card,
  .details-card,
  .process-card {
    padding: var(--space-5);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.52);
  }

  .contact-hero {
    width: min(100%, 68rem);
  }

  .contact-hero__content {
    max-width: 38rem;
  }

  .contact-section__header {
    max-width: 42rem;
  }

  .details-card {
    width: min(100%, 56rem);
  }

  .contact-hero__label,
  .contact-section__label {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-hero__title {
    margin: var(--space-2) 0 0;
    max-width: 20ch;
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 2.5vw, 2.45rem);
    line-height: 1.03;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .contact-section__title {
    margin: var(--space-2) 0 0;
    max-width: 22ch;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.35vw, 2.15rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .contact-hero__deck,
  .contact-section__description {
    margin-top: var(--space-4);
    max-width: 42rem;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.7;
  }

  .contact-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .contact-grid,
  .process-grid {
    display: grid;
    gap: var(--space-4);
  }

  .contact-card,
  .process-card {
    display: grid;
    align-content: start;
    gap: var(--space-3);
  }

  .contact-card h3,
  .process-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.12rem, 1.25vw, 1.28rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .contact-card p,
  .process-card p {
    margin: 0;
    max-width: 34ch;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .details-list {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text);
  }

  .details-list li {
    line-height: 1.7;
  }

  .details-list li + li {
    margin-top: 0.75rem;
  }

  @media (min-width: 68rem) {
    .contact-grid,
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 56rem) {
    .contact-page {
      gap: var(--space-6);
    }

    .contact-section + .contact-section {
      padding-top: var(--space-4);
    }

    .contact-hero,
    .contact-card,
    .details-card,
    .process-card {
      border-radius: var(--radius-md);
    }

    .contact-hero__deck,
    .contact-section__description {
      font-size: 1.0625rem;
    }
  }
</style>
