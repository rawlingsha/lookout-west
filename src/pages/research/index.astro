---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

const allArticles = await getCollection("articles");

const publishedArticles = allArticles
  .filter((article) => !article.data.draft)
  .sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  );

const featuredArticle =
  publishedArticles.find((article) => article.data.featured) ??
  publishedArticles[0] ??
  null;

const archiveArticles = publishedArticles.filter(
  (article) => article.id !== featuredArticle?.id
);

const forthcomingArticles = allArticles
  .filter((article) => article.data.draft)
  .sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  );

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  }).format(date);

const toTopicSlug = (value: string) =>
  value.toLowerCase().trim().replace(/\s+/g, "-");
---

<PageLayout
  title="Research"
  description="Original reporting, essays, and economic analysis on the American West."
  eyebrow="Research"
  intro="Original reporting, essays, and economic analysis on land, water, energy, housing, labor, and growth across the American West."
  prose={false}
  contentWidth="wide"
>
  <div class="research-index">
    {featuredArticle && (
      <section class="research-index__section">
        <p class="research-index__label">Featured</p>

        <article class="research-card research-card--featured">
          <p class="research-card__topic">
            <a href={`/research/topics/${toTopicSlug(featuredArticle.data.topics?.[0] ?? featuredArticle.data.topic)}/`}>
              {featuredArticle.data.topic}
            </a>
          </p>
          <h2 class="research-card__title">
            <a href={`/research/${featuredArticle.id}/`}>
              {featuredArticle.data.title}
            </a>
          </h2>
          <p class="research-card__deck">{featuredArticle.data.deck}</p>
          <div class="research-card__meta">
            <span>{featuredArticle.data.author}</span>
            <span aria-hidden="true">•</span>
            <time datetime={featuredArticle.data.publishDate.toISOString()}>
              {formatDate(featuredArticle.data.publishDate)}
            </time>
          </div>
        </article>
      </section>
    )}

    {archiveArticles.length > 0 && (
      <section class="research-index__section">
        <p class="research-index__label">Archive</p>

        <div class="research-grid research-grid--archive">
          {archiveArticles.map((article) => (
            <article class="research-card">
              <p class="research-card__topic">
                <a href={`/research/topics/${toTopicSlug(article.data.topics?.[0] ?? article.data.topic)}/`}>
                  {article.data.topic}
                </a>
              </p>
              <h2 class="research-card__title research-card__title--archive">
                <a href={`/research/${article.id}/`}>{article.data.title}</a>
              </h2>
              <p class="research-card__deck">{article.data.deck}</p>
              <div class="research-card__meta">
                <span>{article.data.author}</span>
                <span aria-hidden="true">•</span>
                <time datetime={article.data.publishDate.toISOString()}>
                  {formatDate(article.data.publishDate)}
                </time>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {forthcomingArticles.length > 0 && (
      <section class="research-index__section">
        <p class="research-index__label">Forthcoming</p>

        <div class="research-grid research-grid--forthcoming">
          {forthcomingArticles.map((article) => (
            <article class="research-card research-card--forthcoming">
              <p class="research-card__topic">
                <a href={`/research/topics/${toTopicSlug(article.data.topics?.[0] ?? article.data.topic)}/`}>
                  {article.data.topic}
                </a>
              </p>
              <h2 class="research-card__title research-card__title--archive">
                {article.data.title}
              </h2>
              <p class="research-card__deck">{article.data.deck}</p>
              <p class="research-card__status">In development</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="research-index__section">
      <div class="research-cta">
        <p class="research-cta__label">Advisory</p>
        <h2 class="research-cta__title">
          Need a briefing, custom research, or a speaker grounded in the same editorial system?
        </h2>
        <p class="research-cta__deck">
          The consulting lane is built to extend the publication’s judgment into
          decision-useful work for institutions operating across the West.
        </p>

        <div class="research-cta__actions">
          <a class="button button--primary" href="/services">View services</a>
          <a class="button" href="/contact">Contact Lookout West</a>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .research-index {
    display: grid;
    gap: var(--space-8);
  }

  .research-index__section {
    display: grid;
    gap: var(--space-4);
  }

  .research-index__label,
  .research-card__topic,
  .research-cta__label {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .research-grid {
    display: grid;
    gap: var(--space-4);
  }

  .research-card,
  .research-cta {
    padding: var(--space-5);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.6);
  }

  .research-card--featured {
    padding: var(--space-6);
  }

  .research-card__topic {
    margin-bottom: var(--space-3);
  }

  .research-card__topic a {
    color: inherit;
    text-decoration: none;
  }

  .research-card__topic a:hover,
  .research-card__topic a:focus-visible {
    color: var(--color-accent);
  }

  .research-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .research-card__title--archive {
    font-size: clamp(1.65rem, 2.4vw, 2.35rem);
  }

  .research-card__title a:hover,
  .research-card__title a:focus-visible {
    color: var(--color-accent);
  }

  .research-card__deck,
  .research-cta__deck {
    margin: var(--space-4) 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.2vw, 1.125rem);
    line-height: 1.7;
    max-width: 52rem;
  }

  .research-card__meta,
  .research-card__status {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  .research-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .research-cta__title {
    margin: var(--space-2) 0 0;
    max-width: 18ch;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .research-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  @media (min-width: 64rem) {
    .research-grid--archive,
    .research-grid--forthcoming {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 56rem) {
    .research-index {
      gap: var(--space-7);
    }

    .research-card,
    .research-cta {
      border-radius: var(--radius-md);
    }

    .research-card--featured {
      padding: var(--space-5);
    }
  }
</style>
