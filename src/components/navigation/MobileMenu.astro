---
import { primaryNav } from "../../data/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const normalizePath = (value: string) => value.replace(/\/+$/, "") || "/";
const isActive = (href: string) => normalizePath(currentPath) === normalizePath(href);

const panelId = "mobile-menu-panel";
---

<div class="mobile-menu" data-mobile-menu>
  <button
    class="mobile-menu__toggle"
    type="button"
    aria-expanded="false"
    aria-controls={panelId}
    data-mobile-menu-toggle
  >
    <span class="visually-hidden">Toggle navigation menu</span>
    <span class="mobile-menu__label">Menu</span>
  </button>

  <nav
    id={panelId}
    class="mobile-menu__panel"
    aria-label="Mobile navigation"
    hidden
    data-mobile-menu-panel
  >
    <ul class="mobile-menu__list">
      {primaryNav.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script is:inline src="/scripts/mobile-menu.js"></script>
