---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
} = Astro.props;
---

<div class={`section-heading section-heading--${align} ${className}`.trim()}>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <h2 class="section-heading__title">{title}</h2>
  {description && <p class="section-heading__description">{description}</p>}
</div>

<style>
  .section-heading {
    max-width: 46rem;
  }

  .section-heading--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-heading__eyebrow {
    margin: 0 0 var(--space-2);
    color: var(--color-accent);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading__title {
    margin: 0;
    max-width: 12ch;
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 5vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .section-heading__description {
    margin: var(--space-4) 0 0;
    max-width: 40rem;
    color: var(--color-muted);
    font-size: clamp(1.0625rem, 1.25vw, 1.18rem);
    line-height: 1.7;
  }

  @media (max-width: 56rem) {
    .section-heading__title {
      font-size: clamp(2rem, 10vw, 3.2rem);
    }

    .section-heading__description {
      font-size: 1.0625rem;
    }
  }
</style>
